#!/bin/sh
# Refresh the sheet tab→gid map (app.js) before each commit. Network-tolerant:
# if the fetch fails (offline in the Alps) the script exits non-zero and we keep
# the existing map rather than blocking the commit. Enable once per clone with:
#   git config core.hooksPath .githooks
if command -v python3 >/dev/null 2>&1 && python3 scripts/update-gids.py; then
  git add app.js
fi

# Warn (never block) on CLAUDE.md drift: file refs that vanished + undocumented
# root files. Prints its own findings; the || keeps a broken doc from blocking a
# commit (run `python3 scripts/doc-lint.py` for a real exit code / in CI).
if command -v python3 >/dev/null 2>&1; then
  python3 scripts/doc-lint.py || echo "  (doc-lint: CLAUDE.md may be stale — not blocking)"
fi

# Warn (never block) when a commit touches a precached SHELL file but leaves the
# service-worker version V unbumped — the fix would land in the repo but never
# reach installed clients (cache-first). Run `python3 scripts/sw-lint.py` for CI.
if command -v python3 >/dev/null 2>&1; then
  python3 scripts/sw-lint.py || echo "  (sw-lint: bump V in sw.js — not blocking)"
fi
exit 0
