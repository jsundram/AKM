.DS_Store

# test tooling (installed by the session-start hook / `npm install`)
node_modules/

# python bytecode (from running the scripts/ tools)
__pycache__/
*.pyc

# source archives (map + roster), not for the public repo
*.zip

# plaintext concert-recording links — only the encrypted recordings.enc.js ships (build-recordings.js)
recordings.json
# local recordings password for build-recordings.js (REC_PW=…) — never commit a secret
.env

# network diagram previews (bake in participant names — regenerate locally)
network-preview-*.svg
network-ego-*.svg

# local dev scratch (e.g. _settest.html preselects an identity to skip the picker)
_*.html
